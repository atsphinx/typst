{#-
  Base theme of atsphinx-typst
  ============================

  This implements simple reporing style.
  It has these settings:

  * Cover page.
  * Outline of contents.
  * Contents with page number on footer layout.

  This is designed by 3 blocks of Jinja.

  meta
      Manage PDF metadata, page size and settings overall Typst document.
  layout
      Layout settings of page and components.
  content
      Body of document that only display on paper.
-#}
{%- block meta %}
{{ packages.code }}

{#- 
  To set PDF metadata.

  :ref: https://typst.app/docs/reference/model/document/
#}
#set document(
  title: [{{ title }}],
  {% if author %}
  {# NOTE: Hack to use only current implements #}
  author: {{ author|tojson }},
  {% endif %}
)
{%- endblock %}

{% if font %}
#set text(font: "{{ font }}")
{% endif %}

{%- block layout %}
{% include './layout.typ' %}
{%- endblock %}

{%- block content %}
  {%- block cover %}
    {% include './cover.typ' %}
  {% endblock %}

  {%- block outline %}
    #show: cleanPage
    #outline()
  {% endblock %}

  {%- block document %}
    #show: contentPage

{{ body|safe }}
  {% endblock %}

{%- endblock %}
